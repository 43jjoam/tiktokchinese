{
  "name": "tiktokchinese",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:lan": "VITE_DEV_LISTEN_ALL=1 vite",
    "build": "tsc -b && vite build && cp dist/index.html dist/404.html",
    "preview": "vite preview --host --port 5173",
    "setup:env": "node scripts/setup-env-interactive.mjs",
    "setup:env:blank": "node scripts/copy-env-example.mjs",
    "check:supabase-env": "node scripts/check-supabase-env.mjs",
    "videos:storage-keys": "node scripts/list-video-storage-keys.mjs",
    "test:storage-url": "node scripts/test-storage-signed-url.mjs",
    "mascot:install": "node scripts/install-mascot-video.mjs",
    "words:seed-sql": "node scripts/generate-words-seed.mjs",
    "words:metadata-seed-sql": "tsx scripts/generate-word-metadata-seed.ts",
    "words:tag-pos-openai": "tsx scripts/tag-pos-openai.ts",
    "words:check-pos-tags": "vitest run src/lib/__tests__/posTagResolution.test.ts",
    "configure:supabase-auth-smtp": "node scripts/configure-supabase-auth-smtp-resend.mjs",
    "deploy:send-streak-reminders": "supabase functions deploy send-streak-reminders",
    "deploy:notify-referrer-join": "supabase functions deploy notify-referrer-join",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo:solid-video": "playwright test --config=e2e/playwright.solid-video.config.ts && node scripts/print-latest-playwright-video.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:prepush": "vitest run && playwright test",
    "test:load": "node scripts/run-k6-engagement.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.0",
    "framer-motion": "^11.3.26",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-icons": "^16.13.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.21.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "@playwright/test": "^1.51.0",
    "jsdom": "^26.0.0",
    "vitest": "^3.0.9"
  }
}
