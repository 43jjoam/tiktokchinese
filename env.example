# Copy to .env.local (do not commit secrets)

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Exact Storage bucket id for Chinese Characters 1 videos (private bucket + signed URLs)
VITE_CHINESE_CHARACTERS_1_VIDEO_BUCKET=chinese character 1 _videos

# Optional: signed URL lifetime in seconds (default 30 days in code)
# VITE_VIDEO_SIGN_URL_EXPIRY_SEC=604800
