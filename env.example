# Easiest: `npm run setup:env` (interactive) OR `npm run setup:env:blank` then edit .env.local.
# Manual: copy this file to .env.local and fill URL + anon key. Restart `npm run dev` after edits.
#
# Storage setup (once in Supabase): run supabase/setup_storage_private_buckets_all.sql
# (or setup_chinese_characters_1_videos.sql + setup_hsk1_videos.sql separately)
# Upload MP4s to bucket root. Keys can match video_storage_path (M-dad-01.mp4) OR spaced names
# from macOS uploads (M dad 01.mp4, or M  lost 36.mp4) — the app tries both.
# Optional static fallback: place the same filenames under public/videos/

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Magic link / Auth emails: Supabase default SMTP only delivers to org team addresses.
# Use Resend SMTP once (not stored in this file — run from your machine):
#   export SUPABASE_ACCESS_TOKEN=   # https://supabase.com/dashboard/account/tokens
#   export SUPABASE_PROJECT_REF=    # project id from https://YOUR_REF.supabase.co
#   export RESEND_API_KEY=          # same as Edge Function secret (re_...)
#   npm run configure:supabase-auth-smtp
# Optional: SMTP_ADMIN_EMAIL=noreply@your-verified-domain  SMTP_SENDER_NAME="Chinese Flash"
# See scripts/configure-supabase-auth-smtp-resend.mjs
#
# Magic link redirect (default in app: https://YOUR_DOMAIN/auth/callback/ ). Add the same URL under
# Supabase → Authentication → URL Configuration → Redirect URLs, e.g.:
#   https://chineseflash.com/auth/callback
#   https://chineseflash.com/auth/callback/**
# Override only if needed:
# VITE_AUTH_REDIRECT_URL=https://chineseflash.com/auth/callback/
#
# If magic links fail inside Outlook / in-app browsers, edit Supabase → Authentication → Email
# templates → Magic link: replace the button href with a token_hash URL (query params survive
# better than #hash tokens), e.g.:
#   <a href="{{ .SiteURL }}/auth/callback?token_hash={{ .TokenHash }}&type=magiclink">Log in</a>
# Keep {{ .SiteURL }} aligned with your Site URL in Auth settings (e.g. https://chineseflash.com).

# Library activation: deploy Edge Function `redeem-activation` (uses service role; avoids RLS/client issues).
#   supabase functions deploy redeem-activation
# Secrets (same as other functions): SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY
#
# Engagement (Phase 1): Edge Function `record-engagement` + anon reads on `engagement_events`.
# Salt for SHA-256 device_hash on HTTPS (ignored on localhost — app uses dev-<uuid> instead).
VITE_APP_ENGAGEMENT_SALT=
# Optional: override functions base (default: ${VITE_SUPABASE_URL}/functions/v1)
# VITE_SUPABASE_FUNCTIONS_URL=https://xxxx.supabase.co/functions/v1

# Exact Storage bucket id (must match bucket in Supabase; default matches setup SQL)
VITE_CHINESE_CHARACTERS_1_VIDEO_BUCKET=chinese character 1 _videos

# HSK 1 deck videos: bucket `HSK_1`, object keys `success_ones/HSK1-*.mp4` (set per word as video_storage_bucket / video_storage_path in src/data/hsk1Words.ts)

# Optional: signed URL lifetime in seconds (default 7 days in code)
# VITE_VIDEO_SIGN_URL_EXPIRY_SEC=604800

# Optional: swipe-left mascot video if you do not put MP4 in public/images/ (Supabase public URL, etc.)
# VITE_SWIPE_LEFT_MASCOT_VIDEO_URL=https://your-project.supabase.co/storage/v1/object/public/your-bucket/mascot.mp4
# VITE_SWIPE_LEFT_MASCOT_WEBM_URL=https://.../mascot.webm

# Library: unpurchased cards load covers from Supabase `decks` (anon SELECT on catalog deck ids) — same art as when owned, dimmed.
# Optional override per catalog key if needed (overrides DB):
# VITE_LIBRARY_DECK_PREVIEWS={"hsk-1":"https://...","hsk-2":"https://..."}
#
# Edge Function `shopify-webhook` (Supabase Dashboard → Edge Functions → shopify-webhook → Secrets):
#   RESEND_API_KEY, SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, optional SHOPIFY_WEBHOOK_SECRET
# Optional RESEND_FROM — e.g. "Chinese Flash <noreply@chineseflash.com>" ONLY after that domain is
# verified in Resend. If purchase emails stop delivering, Resend often rejects unverified From domains;
# the function defaults to Bestling <noreply@bestling.net> when RESEND_FROM is unset.
